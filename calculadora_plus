        // Corrigi o nome do handler para o mesmo que o Designer registra: button21_Click
        // inverte o sinal do número atualmente mostrado no visor
        private async void button21_Click(object sender, EventArgs e)
        {
            var btn = sender as Button;
            if (btn != null)
                await FlashButtonAsync(btn, Color.MediumPurple, 1, 100);

            var text = lblVisor.Text?.Trim() ?? "0";

            // evita operar em mensagens de erro
            if (text.Equals("Erro", StringComparison.OrdinalIgnoreCase) || text == "")
                return;

            var culture = CultureInfo.CurrentCulture;
            var styles = System.Globalization.NumberStyles.Number;

            // tenta parse seguro com a cultura corrente (aceita agrupadores e vírgula/ponto conforme cultura)
            if (decimal.TryParse(text, styles, culture, out decimal valor))
            {
                valor = -valor;
                lblVisor.Text = valor.ToString(culture);
            }
            else
            {
                // segunda tentativa: normalizar vírgula/ponto e tentar com InvariantCulture
                var alt = text.Replace(".", culture.NumberFormat.NumberDecimalSeparator)
                              .Replace(",", culture.NumberFormat.NumberDecimalSeparator);
                if (decimal.TryParse(alt, styles, culture, out valor))
                {
                    valor = -valor;
                    lblVisor.Text = valor.ToString(culture);
                }
                else
                {
                    // fallback simples: troca manualmente o sinal no texto
                    if (text.StartsWith("-"))
                        lblVisor.Text = text.Substring(1);
                    else if (text != "0")
                        lblVisor.Text = "-" + text;
                }
            }

            // garante que o visor não será imediatamente sobrescrito
            vLimparVisor = false;
        }

        // Botão "=" corrigido: trata operações +, -, x (ou *), / e ^ (potência), valida entradas e divisão por zero.
        private async void bntigual_Click(object sender, EventArgs e)
        {
            var btn = sender as Button;
            if (btn != null)
                _ = FlashButtonAsync(btn, Color.MediumPurple, 1, 100);

            // valida entrada atual
            if (!decimal.TryParse(lblVisor.Text, out decimal atual))
            {
                lblVisor.Text = "Erro";
                return;
            }

            if (string.IsNullOrEmpty(vOperacao))
            {
                // sem operação selecionada, nada a calcular
                return;
            }

            decimal resultado = 0m;
            try
            {
                switch (vOperacao)
                {
                    case "+":
                        resultado = vNumAnt + atual;
                        break;
                    case "-":
                        resultado = vNumAnt - atual;
                        break;
                    case "x":
                    case "X":
                    case "*":
                        resultado = vNumAnt * atual;
                        break;
                    case "/":
                        if (atual == 0m)
                        {
                            lblVisor.Text = "Erro: /0";
                            lblHistorico.Text = "";
                            vOperacao = null;
                            vLimparVisor = true;
                            return;
                        }
                        resultado = vNumAnt / atual;
                        break;
                    case "^":
                        // usa Math.Pow com conversão para double
                        resultado = (decimal)Math.Pow((double)vNumAnt, (double)atual);
                        break;
                    default:
                        lblVisor.Text = "Op inválida";
                        return;
                }

                lblVisor.Text = resultado.ToString();
                lblHistorico.Text = $"{vNumAnt} {vOperacao} {atual} =";
                // prepara para próxima operação: resultado vira número anterior
                vNumAnt = resultado;
                vLimparVisor = true;
                vOperacao = null;
            }
            catch (Exception)
            {
                lblVisor.Text = "Erro";
            }
        }

