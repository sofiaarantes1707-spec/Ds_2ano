        // helper assíncrono para "piscar" um botão
        private async Task FlashButtonAsync(Button btn, Color flashColor, int flashes = 1, int intervalMs = 0)
        {
            if (btn == null) return;
            var original = btn.BackColor;
            for (int i = 0; i < flashes; i++)
            {
                btn.BackColor = flashColor;
                await Task.Delay(intervalMs);
                btn.BackColor = original;
                await Task.Delay(intervalMs);
            }
        }

        // agora event handlers são assíncronos para usar FlashButtonAsync
        private async void f_digitos(object sender, EventArgs e)
        {
            var btn = sender as Button;
            if (btn != null)
            {
                _ = FlashButtonAsync(btn, Color.MediumPurple, 1, 100);
            }

            string digito = ((Button)sender).Text;
            if (string.IsNullOrEmpty(lblVisor.Text) || lblVisor.Text == "0" || vLimparVisor)
            {
                lblVisor.Text = "";
                vLimparVisor = false;
            }
            lblVisor.Text += digito; // mostra no visor

            // atualiza vNumAtual e o histórico imediatamente com o valor do visor
            var culture = CultureInfo.CurrentCulture;
            if (decimal.TryParse(lblVisor.Text, System.Globalization.NumberStyles.Number, culture, out decimal atual))
            {
                vNumAtual = atual;
            }

            // se já existe uma operação selecionada, mantenha o primeiro número + operador no histórico
            if (!string.IsNullOrEmpty(vOperacao))
            {
                lblHistorico.Text = $"{vNumAnt.ToString(culture)} {vOperacao} {lblVisor.Text}";
            }
            else
            {
                lblHistorico.Text = lblVisor.Text;
            }

            this.ActiveControl = null;
            //ou //lblVisor.Focus();
            //apertar o botao - nao deixar o foco no botão
            //o enter executa o botao que tem o foco, entao se tiver o foco no botao 1, o enter vai apertar o 1
        }

        private async void f_operacoes(object sender, EventArgs e)
        {
            var btn = sender as Button;
            if (btn != null)
            {
                await FlashButtonAsync(btn, Color.MediumPurple, 1, 100);
            }

            // tenta salvar o número atual antes de operar
            vNumAnt = decimal.Parse(lblVisor.Text);
            vOperacao = ((Button)sender).Text;
            vLimparVisor = true; //intrução de atribuição - atribui o valor verdadeiro
            this.ActiveControl = null;
            lblHistorico.Text = vNumAnt + " " + vOperacao;
        }

