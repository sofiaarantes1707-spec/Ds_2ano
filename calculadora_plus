        private void CalculadoraPlus_KeyDown(object sender, KeyEventArgs e)
        {
            // exibe código da tecla (útil para debug)
            label1.Text = e.KeyCode.ToString();

            // fechar com ESC
            if (e.KeyCode == Keys.Escape)
            {
                Close();
                e.SuppressKeyPress = true;
                return;
            }

            // Digitos: fileira superior (D0..D9)
            if (e.KeyCode >= Keys.D0 && e.KeyCode <= Keys.D9)
            {
                string digit = (e.KeyCode - Keys.D0).ToString();
                var btn = new Button { Text = digit };
                f_digitos(btn, EventArgs.Empty);
                e.SuppressKeyPress = true;
                return;
            }

            // Digitos: Numpad (NumPad0..NumPad9)
            if (e.KeyCode >= Keys.NumPad0 && e.KeyCode <= Keys.NumPad9)
            {
                string digit = (e.KeyCode - Keys.NumPad0).ToString();
                var btn = new Button { Text = digit };
                f_digitos(btn, EventArgs.Empty);
                e.SuppressKeyPress = true;
                return;
            }

            // Vírgula / ponto decimal
            if (e.KeyCode == Keys.Decimal || e.KeyCode == Keys.Oemcomma || e.KeyCode == Keys.OemPeriod)
            {
                // chama o handler da vírgula (usa o botão do Designer)
                btnVirgula_Click(btnVirgula, EventArgs.Empty);
                e.SuppressKeyPress = true;
                return;
            }

            // Operadores: tenta mapear teclas comuns
            if (e.KeyCode == Keys.Add || e.KeyCode == Keys.Oemplus)
            {
                f_operacoes(mais, EventArgs.Empty);
                e.SuppressKeyPress = true;
                return;
            }
            if (e.KeyCode == Keys.Subtract || e.KeyCode == Keys.OemMinus)
            {
                f_operacoes(menos, EventArgs.Empty);
                e.SuppressKeyPress = true;
                return;
            }
            if (e.KeyCode == Keys.Multiply)
            {
                f_operacoes(multiplicacao, EventArgs.Empty);
                e.SuppressKeyPress = true;
                return;
            }
            if (e.KeyCode == Keys.Divide || e.KeyCode == Keys.Oem2)
            {
                f_operacoes(divisao, EventArgs.Empty);
                e.SuppressKeyPress = true;
                return;
            }

            // Backspace -> apagar último dígito
            if (e.KeyCode == Keys.Back)
            {
                btnBack_Click(btnBack, EventArgs.Empty);
                e.SuppressKeyPress = true;
                return;
            }

            // Delete -> CE (limpar visor atual)
            if (e.KeyCode == Keys.Delete)
            {
                button4_Click(button4, EventArgs.Empty);
                e.SuppressKeyPress = true;
                return;
            }

            // Enter/Return -> =
            if (e.KeyCode == Keys.Enter || e.KeyCode == Keys.Return)
            {
                bntigual_Click(btnIgual, EventArgs.Empty);
                e.SuppressKeyPress = true;
                return;
            }
        }
