        private void button3_Click(object sender, EventArgs e)
        {
            double a, b;

            if (!double.TryParse(textBox1.Text, out a) ||
                !double.TryParse(textBox2.Text, out b))
            {
                resultado.Text = "Digite números válidos!";
                return;
            }

            string resultadoFinal = "";

            if (!soma.Checked)
            {
                if (sub.Checked)
                {
                    resultadoFinal = "A subtração é " + (a - b).ToString();
                }
                else if (mult.Checked)
                {
                    resultadoFinal = "O produto é " + (a * b).ToString();
                }
                else if (div.Checked)
                {
                    if (b == 0)
                        resultadoFinal = "Erro: divisão por 0";
                    else
                        resultadoFinal = "A divisão é " + (a / b).ToString();
                }
                else if (comp.Checked)
                {
                    if (a > b)
                        resultadoFinal = $"{a} > {b}";
                    else if (a < b)
                        resultadoFinal = $"{a} < {b}";
                    else
                        resultadoFinal = $"{a} = {b}";
                }
                else if (parimpar.Checked)
                {
                    long somaInt = (long)(a + b);
                    if (somaInt % 2 == 0)
                        resultadoFinal = "A soma é Par";
                    else
                        resultadoFinal = "A soma é Ímpar";
                }
                else
                {
                    resultadoFinal = "Selecione uma operação";
                }
            }
            else
            {
                resultadoFinal = "A soma é " + (a + b).ToString();
            }

            resultado.Text = resultadoFinal;
        }

