        private void AplicarEstilo()
        {
            this.BackColor = Color.FromArgb(25, 25, 35);

            Button[] botoes = { btobj01, btobj02, btobj03, btobj04, btobj05, btobj06 };
            foreach (var bt in botoes)
            {
                bt.BackColor = Color.FromArgb(52, 152, 219);
                bt.ForeColor = Color.White;
                bt.Font = new Font("Segoe UI", 11, FontStyle.Bold);
                bt.FlatStyle = FlatStyle.Flat;
                bt.FlatAppearance.BorderSize = 0;
                bt.Cursor = Cursors.Hand;
                bt.TextAlign = ContentAlignment.MiddleLeft;
            }

            // Cores diferentes para cada botão
            btobj01.BackColor = Color.FromArgb(231, 76, 60);
            btobj02.BackColor = Color.FromArgb(155, 89, 182);
            btobj03.BackColor = Color.FromArgb(46, 204, 113);
            btobj04.BackColor = Color.FromArgb(241, 196, 15);
            btobj05.BackColor = Color.FromArgb(230, 126, 34);
            btobj06.BackColor = Color.FromArgb(142, 68, 173);

            Label[] labels = { txtNome, txtEstilo, txtNascimento, txtAlbuns, txtPremios, txtMusicaF };
            foreach (var lbl in labels)
            {
                lbl.Font = new Font("Segoe UI", 11, FontStyle.Regular);
                lbl.ForeColor = Color.FromArgb(236, 240, 241);
                lbl.BackColor = Color.FromArgb(40, 40, 50);
                lbl.Padding = new Padding(10, 8, 10, 8);
                lbl.Width = 750;
                lbl.AutoSize = false;
            }

            // Estilos específicos para cada label
            txtNome.BackColor = Color.FromArgb(52, 73, 94);
            txtNome.Font = new Font("Segoe UI", 12, FontStyle.Bold);

            txtPremios.BackColor = Color.FromArgb(192, 57, 43);
            txtAlbuns.BackColor = Color.FromArgb(41, 128, 185);
            txtEstilo.BackColor = Color.FromArgb(39, 174, 96);
            txtMusicaF.BackColor = Color.FromArgb(142, 68, 173);
            txtNascimento.BackColor = Color.FromArgb(211, 84, 0);

            img.BorderStyle = BorderStyle.FixedSingle;
            img.SizeMode = PictureBoxSizeMode.Zoom;
            img.BackColor = Color.FromArgb(50, 50, 60);
            img.Width = 350;
            img.Height = 350;
        }
